    "lodash": "^4.17.21",
    "pinia": "^2.1.4",
    "vue": "^3.3.4",
    "vue-axios": "^3.5.2",
    "vue-i18n": "^9.2.2",
    "vue-router": "^4.2.0",
    "vuetify": "^3.3.0"
  },
  "devDependencies": {
    "@mdi/font": "^7.2.96",
    "@vitejs/plugin-vue": "^4.2.3",
    "@vue/cli": "^5.0.8",
    "@vue/cli-plugin-e2e-cypress": "^5.0.8",
