# Tennis Team Website Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Django Configuration
# ============================================

# Secret key for Django (generate a new one for production)
# Use: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=django-insecure-change-this-in-production

# Django settings module
DJANGO_SETTINGS_MODULE=tennis_backend.settings.production

# Debug mode (set to False in production)
DEBUG=False

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,webserver

# ============================================
# Database Configuration
# ============================================

# PostgreSQL database URL
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://tennis_user:tennis_password@database:5432/tennis_db

# ============================================
# Celery Configuration
# ============================================

# Celery broker URL (Redis)
CELERY_BROKER_URL=redis://redis:6379/0

# Celery result backend
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ============================================
# Email Configuration
# ============================================

# Email backend (options: console, smtp)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# SMTP settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# Email credentials
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password

# Default from email
DEFAULT_FROM_EMAIL=Tennis Team <noreply@tennis-team.local>

# ============================================
# CORS Configuration
# ============================================

# Allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:8080,https://your-domain.com

# Allow all origins (for development only)
# CORS_ALLOW_ALL_ORIGINS=True

# ============================================
# Security Configuration
# ============================================

# HTTPS settings
SECURE_SSL_REDIRECT=True
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# HSTS settings
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# ============================================
# Application Configuration
# ============================================

# Site name
SITE_NAME=Tennis Team Website

# Site URL
SITE_URL=http://localhost:8080

# ============================================
# Frontend Configuration
# ============================================

# API URL for frontend
VUE_APP_API_URL=http://backend:8000

# ============================================
# Logging Configuration
# ============================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================
# Cache Configuration
# ============================================

# Cache backend
CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
CACHE_LOCATION=redis://redis:6379/1

# ============================================
# Session Configuration
# ============================================

# Session engine
SESSION_ENGINE=django.contrib.sessions.backends.cached_db

# Session cookie age (in seconds)
SESSION_COOKIE_AGE=1209600

# ============================================
# File Upload Configuration
# ============================================

# Media root
MEDIA_ROOT=/app/media

# Static root
STATIC_ROOT=/app/static

# Maximum file upload size (in bytes)
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760

# ============================================
# Development Configuration (override for development)
# ============================================

# For development, you can override settings:
# DEBUG=True
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# CORS_ALLOW_ALL_ORIGINS=True
# SESSION_COOKIE_SECURE=False
# CSRF_COOKIE_SECURE=False
# SECURE_SSL_REDIRECT=False